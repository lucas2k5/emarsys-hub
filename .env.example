# Postgres do hub (porta 5433 no host — ver docker-compose.yml)
POSTGRES_DB=emarsys_hub
POSTGRES_USER=hub
POSTGRES_PASSWORD=

# Conexão usada pela API fora do compose (dev local)
DATABASE_URL=postgresql://hub:senha@localhost:5433/emarsys_hub

# Chave mestra AES-256-GCM para criptografia de credenciais de tenant (Fase 1)
# Gerar com: openssl rand -hex 32
ENCRYPTION_KEY=

# Chave de assinatura JWT — OBRIGATÓRIA; separada da ENCRYPTION_KEY por princípio de separação de segredos
# Gerar com: openssl rand -hex 32
JWT_SECRET=

# URL da API que o painel consome (vazio = modo mock)
NEXT_PUBLIC_API_URL=
